#!/bin/bash
# setup-git-goblin: Automated setup script for git-goblin utilities
# ... (existing content) ...

# Check if git-goblin source line already exists
SOURCE_LINE="source \"$SCRIPT_DIR/git-goblin-functions.sh\""
MEGA_SCRIPT_LINE="source \"$SCRIPT_DIR/mega_script.sh\""

# Check for both old aliases and new source line
HAS_OLD_ALIASES=false
HAS_SOURCE_LINE=false
HAS_MEGA_SCRIPT_LINE=false

if grep -q "# git-goblin aliases - START" "$RC_FILE" 2>/dev/null; then
    HAS_OLD_ALIASES=true
fi

if grep -q "git-goblin-functions.sh" "$RC_FILE" 2>/dev/null; then
    HAS_SOURCE_LINE=true
fi

if grep -q "mega_script.sh" "$RC_FILE" 2>/dev/null; then
    HAS_MEGA_SCRIPT_LINE=true
fi

# Handle old aliases if they exist
if [ "$HAS_OLD_ALIASES" = true ]; then
# ... (existing content) ...
    fi
fi

# Add source line to RC file if not already present
if [ "$HAS_SOURCE_LINE" = true ] && [ "$HAS_MEGA_SCRIPT_LINE" = true ]; then
    print_info "Git Goblin bash functions are already configured in $RC_FILE"
    print_info "No changes needed."
else
    print_info "Adding git-goblin source line to $RC_FILE..."
    
    {
        echo ""
        echo "# git-goblin bash functions - START"
        echo "# Added by setup-git-goblin on $(date)"
        echo "# You can source the main functions file (recommended):"
        if [ "$HAS_SOURCE_LINE" = false ]; then
            echo "$SOURCE_LINE"
        fi
        if [ "$HAS_MEGA_SCRIPT_LINE" = false ]; then
            echo "$MEGA_SCRIPT_LINE"
        fi
        echo "# Or source individual scripts as needed:"
        echo "# source \"$SCRIPT_DIR/hl\""
        echo "# git-goblin bash functions - END"
        echo ""
    } >> "$RC_FILE"
    
    print_success "Source line added to $RC_FILE"
fi

# Make all scripts executable (for both direct execution and sourcing)
print_info "Making scripts executable..."
# ... (existing content) ...
    chmod_count=$((chmod_count + 1))
done < <(find "$SCRIPT_DIR" -maxdepth 1 -name "*.py" -type f -print0 2>/dev/null)

# Make the functions file executable
if [ -f "$SCRIPT_DIR/git-goblin-functions.sh" ]; then
    chmod +x "$SCRIPT_DIR/git-goblin-functions.sh"
    chmod_count=$((chmod_count + 1))
fi

if [ -f "$SCRIPT_DIR/mega_script.sh" ]; then
    chmod +x "$SCRIPT_DIR/mega_script.sh"
    chmod_count=$((chmod_count + 1))
fi

print_success "Made $chmod_count files executable"

