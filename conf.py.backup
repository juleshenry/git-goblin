import os
import sys
sys.path.insert(0, os.path.abspath('../..'))

project = 'ghee'
copyright = '2026, Jules Henry'
author = 'Jules Henry'

version = '1.0.0'
release = '1.0.0'

# -- General configuration ---------------------------------------------------
extensions = [
    'sphinx.ext.autodoc',
    'sphinx.ext.viewcode',
    'sphinx.ext.napoleon',
    'myst_parser'
]

# Configure myst-parser to enable useful extensions
myst_enable_extensions = [
    "colon_fence",
    "html_image",
    "html_admonition",
]
# Ignore missing anchors that we link to in the markdown
suppress_warnings = ["myst.xref_missing"]

templates_path = ['_templates']
exclude_patterns = ['_build', 'Thumbs.db', '.DS_Store']

# -- Options for HTML output -------------------------------------------------
html_theme = 'sphinx_rtd_theme'
html_static_path = ['_static']
