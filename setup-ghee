#!/bin/bash
# setup-ghee: Automated setup script for ghee utilities
# Installs ghee into your shell (bash or zsh) by sourcing the
# function and alias files from your RC file.
#
# Usage:
#   ./setup-ghee           # install
#   ./setup-ghee --remove  # uninstall

set -euo pipefail

# ============================================================================
# Colors & helpers
# ============================================================================

_red='\033[0;31m'
_green='\033[0;32m'
_yellow='\033[0;33m'
_cyan='\033[0;36m'
_bold='\033[1m'
_dim='\033[2m'
_reset='\033[0m'

print_ok()   { echo -e "${_green}${_bold}[ok]${_reset} $*"; }
print_info() { echo -e "${_cyan}[..]${_reset} $*"; }
print_warn() { echo -e "${_yellow}[!!]${_reset} $*"; }
print_err()  { echo -e "${_red}[ERR]${_reset} $*" >&2; }

# ============================================================================
# Resolve script directory (works even when symlinked)
# ============================================================================

resolve_dir() {
    local source="${BASH_SOURCE[0]}"
    while [ -L "$source" ]; do
        local dir
        dir=$(cd -P "$(dirname "$source")" && pwd)
        source=$(readlink "$source")
        [[ "$source" != /* ]] && source="$dir/$source"
    done
    cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_dir)"

# ============================================================================
# Detect shell RC file
# ============================================================================

detect_rc_file() {
    local shell_name
    shell_name=$(basename "$SHELL")

    case "$shell_name" in
        zsh)  echo "${HOME}/.zshrc" ;;
        bash)
            # macOS uses .bash_profile for login shells
            if [ -f "${HOME}/.bash_profile" ] && [[ "$OSTYPE" == darwin* ]]; then
                echo "${HOME}/.bash_profile"
            else
                echo "${HOME}/.bashrc"
            fi
            ;;
        *)
            print_warn "Unknown shell: $shell_name -- defaulting to ~/.bashrc"
            echo "${HOME}/.bashrc"
            ;;
    esac
}

RC_FILE="$(detect_rc_file)"

# ============================================================================
# Marker lines (used to find our block in the RC file)
# ============================================================================

MARKER_START="# ghee bash functions - START"
MARKER_END="# ghee bash functions - END"
SOURCE_FUNCTIONS="export PATH=\"${SCRIPT_DIR}/bin:${SCRIPT_DIR}/tools:\$PATH\"
source \"${SCRIPT_DIR}/ghee-functions.sh\"
for _gg_mod in \"${SCRIPT_DIR}/modules\"/*.sh; do
    source \"\$_gg_mod\"
done"

# ============================================================================
# Uninstall mode
# ============================================================================

uninstall() {
    print_info "Removing ghee from ${RC_FILE}..."

    if ! grep -q "$MARKER_START" "$RC_FILE" 2>/dev/null; then
        print_warn "ghee block not found in ${RC_FILE}. Nothing to remove."
        return 0
    fi

    # Back up before modifying
    local backup="${RC_FILE}.bak.$(date +%Y%m%d-%H%M%S)"
    cp "$RC_FILE" "$backup"
    print_info "Backup created: ${backup}"

    # Remove the block between markers (inclusive)
    local tmp
    tmp=$(mktemp)
    awk "
        /${MARKER_START//\//\\/}/  { skip=1; next }
        /${MARKER_END//\//\\/}/    { skip=0; next }
        !skip                      { print }
    " "$RC_FILE" > "$tmp"
    mv "$tmp" "$RC_FILE"

    print_ok "ghee removed from ${RC_FILE}."
    print_info "Reload your shell:  source ${RC_FILE}"
    return 0
}

if [[ "${1:-}" == "--remove" || "${1:-}" == "--uninstall" ]]; then
    uninstall
    exit 0
fi

# ============================================================================
# Banner
# ============================================================================

echo ""
echo -e "${_bold}${_green}  ghee installer${_reset}"
echo -e "${_dim}  ────────────────────────────────────────${_reset}"
echo ""

# ============================================================================
# Verify required files exist
# ============================================================================

missing=0
for f in ghee-functions.sh modules/git_workflow.sh; do
    if [ ! -f "${SCRIPT_DIR}/${f}" ]; then
        print_err "Required file not found: ${SCRIPT_DIR}/${f}"
        missing=1
    fi
done

if [ "$missing" -eq 1 ]; then
    print_err "Aborting. Please make sure you're running this from the ghee directory."
    exit 1
fi

print_ok "Found ghee-functions.sh"
print_ok "Found modules/ directory"

# ============================================================================
# Detect shell
# ============================================================================

SHELL_NAME=$(basename "$SHELL")
print_info "Detected shell: ${_bold}${SHELL_NAME}${_reset}"
print_info "RC file: ${_bold}${RC_FILE}${_reset}"

# ============================================================================
# Back up RC file
# ============================================================================

if [ -f "$RC_FILE" ]; then
    BACKUP="${RC_FILE}.bak.$(date +%Y%m%d-%H%M%S)"
    cp "$RC_FILE" "$BACKUP"
    print_ok "Backed up ${RC_FILE} -> ${BACKUP}"
else
    print_info "${RC_FILE} does not exist yet -- will create it."
    touch "$RC_FILE"
fi

# ============================================================================
# Migrate old alias-based config (if present)
# ============================================================================

if grep -q "# ghee aliases - START" "$RC_FILE" 2>/dev/null; then
    print_warn "Found old ghee alias block. Removing it..."
    tmp=$(mktemp)
    awk '
        /# ghee aliases - START/ { skip=1; next }
        /# ghee aliases - END/   { skip=0; next }
        !skip                          { print }
    ' "$RC_FILE" > "$tmp"
    mv "$tmp" "$RC_FILE"
    print_ok "Old alias block removed."
fi

# ============================================================================
# Remove existing ghee function block (for clean re-install)
# ============================================================================

if grep -q "$MARKER_START" "$RC_FILE" 2>/dev/null; then
    print_info "Existing ghee block found -- replacing it..."
    tmp=$(mktemp)
    awk "
        /${MARKER_START//\//\\/}/  { skip=1; next }
        /${MARKER_END//\//\\/}/    { skip=0; next }
        !skip                      { print }
    " "$RC_FILE" > "$tmp"
    mv "$tmp" "$RC_FILE"
fi

# ============================================================================
# Write source block to RC file
# ============================================================================

{
    echo ""
    echo "$MARKER_START"
    echo "# Added by setup-ghee on $(date)"
    echo "$SOURCE_FUNCTIONS"
    echo "$MARKER_END"
    echo ""
} >> "$RC_FILE"

print_ok "Source lines added to ${RC_FILE}"

# ============================================================================
# Make all scripts executable
# ============================================================================

print_info "Making scripts executable..."
chmod_count=0

# Shell scripts and Python tools
if [ -d "${SCRIPT_DIR}/bin" ]; then
    find "${SCRIPT_DIR}/bin" -type f -exec chmod +x {} +
    chmod_count=$((chmod_count + $(find "${SCRIPT_DIR}/bin" -type f 2>/dev/null | wc -l)))
fi

if [ -d "${SCRIPT_DIR}/tools" ]; then
    find "${SCRIPT_DIR}/tools" -type f -exec chmod +x {} +
    chmod_count=$((chmod_count + $(find "${SCRIPT_DIR}/tools" -type f 2>/dev/null | wc -l)))
fi

if [ -f "${SCRIPT_DIR}/setup-ghee" ]; then
    chmod +x "${SCRIPT_DIR}/setup-ghee"
    chmod_count=$((chmod_count + 1))
fi

if [ -f "${SCRIPT_DIR}/ghee.py" ]; then
    chmod +x "${SCRIPT_DIR}/ghee.py"
    chmod_count=$((chmod_count + 1))
fi

print_ok "Made ${chmod_count} files executable"

# ============================================================================
# Setup Python Environment
# ============================================================================

print_info "Setting up Python virtual environment..."
if command -v python3 &>/dev/null; then
    python3 -m venv "${SCRIPT_DIR}/ghee-venv"
    "${SCRIPT_DIR}/ghee-venv/bin/pip" install --quiet rich
    print_ok "Python environment ready with 'rich'."
else
    print_warn "python3 not found. Ghee will run without rich formatting."
fi

# ============================================================================
# Summary
# ============================================================================

# Count how many aliases + functions we just installed
alias_count=$(cat "${SCRIPT_DIR}/modules"/*.sh 2>/dev/null | grep -c '^alias ' || echo 0)
func_count=$(cat "${SCRIPT_DIR}/modules"/*.sh 2>/dev/null | grep -c '^[a-zA-Z_-]*()' || echo 0)
gfunc_count=0
total=$((alias_count + func_count + gfunc_count))

echo ""
echo -e "${_bold}${_green}  Installation complete!${_reset}"
echo -e "${_dim}  ────────────────────────────────────────${_reset}"
echo ""
echo -e "  ${_cyan}Shell:${_reset}      ${SHELL_NAME}"
echo -e "  ${_cyan}RC file:${_reset}    ${RC_FILE}"
echo -e "  ${_cyan}Commands:${_reset}   ~${total} aliases & functions"
echo -e "  ${_cyan}Backup:${_reset}     ${BACKUP:-none}"
echo ""
echo -e "  ${_bold}Next steps:${_reset}"
echo ""
echo -e "    ${_green}1.${_reset} Reload your shell:"
echo -e "       ${_dim}source ${RC_FILE}${_reset}"
echo ""
echo -e "    ${_green}2.${_reset} Try the g command:"
echo -e "       ${_dim}g 'git status'${_reset}          # best-guess a shortcut"
echo -e "       ${_dim}G${_reset}                       # interactive fuzzy finder"
echo -e "       ${_dim}g -a 'mycmd' 'desc'${_reset}     # add your own shortcut"
echo ""
echo -e "    ${_green}3.${_reset} See all commands:"
echo -e "       ${_dim}gg-help${_reset}                 # full reference table"
echo -e "       ${_dim}gg-help docker${_reset}           # filter by section"
echo ""
echo -e "  ${_dim}To uninstall: ./setup-ghee --remove${_reset}"
echo ""
